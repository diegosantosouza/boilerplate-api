{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDirs": [
      "./src",
      "./tests"
    ],
    "baseUrl": "./",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@router": [
        "src/router/*"
      ],
      "@shared": [
        "src/shared/*"
      ],
      "@modules": [
        "src/modules/*"
      ],
      "@infrastructure": [
        "src/infrastructure/*"
      ]
    },
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "isolatedModules": true
  }
}
