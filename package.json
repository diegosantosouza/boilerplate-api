{
  "name": "boilerplate-api",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "npm run script:generate-swagger && npm run clean",
    "build": "NODE_ENV=production node esbuild.config.js",
    "start": "node --trace-deprecation --enable-source-maps dist/index.js",
    "dev": "tsx watch --env-file .env src/index.ts",
    "debug": "tsx watch --inspect=0.0.0.0:9229 --env-file .env src/index.ts",
    "consumer:example-sync": "node --trace-deprecation --enable-source-maps dist/consumers/example-sync-consumer/example-sync-consumer.js",
    "consumer:example-sync:dev": "tsx watch --env-file .env src/consumers/example-sync-consumer/example-sync-consumer.ts",
    "cron:example-sync": "node --trace-deprecation --enable-source-maps dist/crons/example-sync-cron/example-sync-cron.js",
    "cron:example-sync:dev": "tsx watch --env-file .env src/crons/example-sync-cron/example-sync-cron.ts",
    "worker:example-background-jobs": "node --trace-deprecation --enable-source-maps dist/workers/example-background-jobs/example-background-jobs.worker.js",
    "worker:example-background-jobs:dev": "tsx watch --env-file .env src/workers/example-background-jobs/example-background-jobs.worker.ts",
    "scheduler:example-background-jobs": "node --trace-deprecation --enable-source-maps dist/schedulers/example-background-jobs/example-background-jobs.scheduler.js",
    "scheduler:example-background-jobs:dev": "tsx watch --env-file .env src/schedulers/example-background-jobs/example-background-jobs.scheduler.ts",
    "lint": "biome lint src/ tests/",
    "lint:fix": "biome lint --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "format:check": "biome format src/ tests/",
    "code:check": "biome check src/ tests/",
    "code:fix": "biome check --write src/ tests/",
    "test": "node --env-file=.env.test ./node_modules/.bin/jest",
    "test:unit": "node --env-file=.env.test ./node_modules/.bin/jest",
    "test:integration": "node --env-file=.env.test ./node_modules/.bin/jest --config jest.integration.config.js",
    "test:watch": "node --env-file=.env.test ./node_modules/.bin/jest --watch",
    "test:coverage": "node --env-file=.env.test ./node_modules/.bin/jest --coverage",
    "test:verbose": "node --env-file=.env.test ./node_modules/.bin/jest --verbose",
    "cache:clear": "docker compose exec redis redis-cli FLUSHALL",
    "script:generate-swagger": "tsx src/scripts/generate-swagger.ts",
    "generate:module": "tsx src/scripts/generate-module.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@testcontainers/mongodb": "^11.13.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.33",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "esbuild": "^0.25.5",
    "jest": "^30.0.3",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "testcontainers": "^11.13.0",
    "ts-jest": "^29.4.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@godaddy/terminus": "^4.12.1",
    "@google-cloud/pubsub": "^5.2.0",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/instrumentation-pino": "^0.60.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "bullmq": "^5.71.0",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "ioredis": "^5.6.1",
    "mongoose": "^8.16.1",
    "mongoose-paginate-v2": "^1.9.1",
    "neverthrow": "^8.2.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^10.0.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.67"
  }
}
