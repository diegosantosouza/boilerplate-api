{
  "name": "boilerplate-api",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "npm run script:generate-swagger && npm run clean",
    "build": "NODE_ENV=production node esbuild.config.js",
    "start": "node --trace-deprecation --enable-source-maps dist/index.js",
    "dev": "tsx watch --env-file .env src/index.ts",
    "debug": "tsx watch --inspect=0.0.0.0:9229 --env-file .env src/index.ts",
    "consumer:example-sync": "node --trace-deprecation --enable-source-maps dist/consumers/example-sync-consumer/example-sync-consumer.js",
    "consumer:example-sync:dev": "tsx watch --env-file .env src/consumers/example-sync-consumer/example-sync-consumer.ts",
    "cron:example-sync": "node --trace-deprecation --enable-source-maps dist/crons/example-sync-cron/example-sync-cron.js",
    "cron:example-sync:dev": "tsx watch --env-file .env src/crons/example-sync-cron/example-sync-cron.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "code:check": "npm run lint && npm run format:check",
    "code:fix": "npm run lint:fix && npm run format",
    "test": "node --env-file=.env.test ./node_modules/.bin/jest",
    "test:watch": "node --env-file=.env.test ./node_modules/.bin/jest --watch",
    "test:coverage": "node --env-file=.env.test ./node_modules/.bin/jest --coverage",
    "test:verbose": "node --env-file=.env.test ./node_modules/.bin/jest --verbose",
    "cache:clear": "docker compose exec redis redis-cli FLUSHALL",
    "script:generate-swagger": "tsx src/scripts/generate-swagger.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.15.33",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "esbuild": "^0.25.5",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "jest": "^30.0.3",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@google-cloud/pubsub": "^5.2.0",
    "axios": "^1.11.0",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "ioredis": "^5.6.1",
    "mongoose": "^8.16.1",
    "mongoose-paginate-v2": "^1.9.1",
    "morgan": "^1.10.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.67"
  }
}
