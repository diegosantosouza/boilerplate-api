# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/boilerplate-api
MONGO_DEBUG=false

# Redis Cache
CACHE_URL=redis://localhost:6379
CACHE_DEFAULT_TTL_SECONDS=60
CACHE_KEY_PREFIX=boilerplate

# BullMQ
BULLMQ_PREFIX=boilerplate-jobs
BULLMQ_DEFAULT_ATTEMPTS=3
BULLMQ_DEFAULT_BACKOFF_MS=5000
BULLMQ_REMOVE_ON_COMPLETE_COUNT=10
BULLMQ_REMOVE_ON_FAIL_COUNT=100
BULLMQ_DEFAULT_WORKER_CONCURRENCY=5
BULLMQ_EXAMPLE_SCHEDULER_EVERY_MS=60000

# Messaging
MESSAGING_DRIVER=gcp-pubsub
GCP_PROJECT_ID=boilerplate-local
PUBSUB_EMULATOR_HOST=http://localhost:9000

# PubSub Topics / Subscriptions
EXAMPLE_SYNC_TOPIC=example-sync
EXAMPLE_SYNC_SUBSCRIPTION=example-sync-sub

# External API (optional)
EXAMPLE_EXTERNAL_API_URL=
EXAMPLE_EXTERNAL_API_TOKEN=
EXAMPLE_EXTERNAL_API_ENDPOINT=/resources

# Rate Limiting
RATE_LIMIT_GLOBAL_POINTS=200
RATE_LIMIT_GLOBAL_DURATION=60
RATE_LIMIT_PUBLIC_POINTS=30
RATE_LIMIT_PUBLIC_DURATION=60
RATE_LIMIT_AUTH_POINTS=60
RATE_LIMIT_AUTH_DURATION=60
RATE_LIMIT_WEBHOOK_POINTS=60
RATE_LIMIT_WEBHOOK_DURATION=60

# Logging
LOG_LEVEL=debug

# Auth
DISABLE_AUTH=false

# OpenTelemetry (optional - leave empty to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=boilerplate-api
